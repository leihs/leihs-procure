{
  "name": "leihs-procurement-ui",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "start": "vite",
    "serve": "vite preview",
    "build": "npm run -s build:i18n && npm run -s build:app",
    "build:app": "vite build",
    "build:i18n": "node src/locale/make-pseudoloc.js",
    "postinstall": "npm run cleanup-typescript",
    "prestart": "npm run -s build:i18n",
    "pretest": "npm run -s build:i18n",
    "cleanup-typescript": "find . -type f -name '*.ts' -or -name '*.tsx' | xargs rm",
    "analyze": "source-map-explorer build/static/js/main.*",
    "analyze-build": "npm run -s build && npm run -s analyze",
    "coverage": "npm test -- --coverage",
    "lint": "npx eslint --fix 'src/' && npm run -s lint:json",
    "ci:lint": "npx eslint --max-warnings=0 'src/' && npm run -s ci:lint:json",
    "lint:json": "npx prettier --write 'src/{,**/}*.json'",
    "ci:lint:json": "npx prettier --list-different 'src/{,**/}*.json'",
    "test": "react-scripts test --env=jsdom"
  },
  "dependencies": {
    "@apollo/client": "^3.8.4",
    "@fortawesome/fontawesome-free-solid": "^5.1.0-3",
    "@fortawesome/fontawesome-svg-core": "^1.2.12",
    "@fortawesome/free-regular-svg-icons": "^5.6.3",
    "@fortawesome/free-solid-svg-icons": "^5.6.3",
    "@fortawesome/react-fontawesome": "^0.2.0",
    "@generouted/react-router": "^1.15.8",
    "@types/node": "^20.5.3",
    "@types/react": "^18.2.21",
    "@types/react-dom": "^18.2.7",
    "@vitejs/plugin-react-swc": "^3.3.2",
    "accounting-js": "^1.1.1",
    "babel-eslint": "^10.1.0",
    "bootstrap": "^4.2.1",
    "browser-info": "^1.2.0",
    "classnames": "^2.3.2",
    "debug": "^3.2.6",
    "downshift": "^1.31.16",
    "eslint": "^8.49.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-standard": "^5.0.0",
    "graphiql": "^0.11.11",
    "graphql": "^14.0.2",
    "graphql-tag": "^2.10.0",
    "lodash": "^4.17.11",
    "luxon": "^1.9.0",
    "moment": "^2.23.0",
    "prop-types": "^15.6.2",
    "pseudoloc": "^1.1.0",
    "react": "^18.2.0",
    "react-app-polyfill": "^3.0.0",
    "react-day-picker": "7.2.4",
    "react-dom": "^18.2.0",
    "react-highlight-words": "^0.11.0",
    "react-router": "^6.16.0",
    "react-router-dom": "^6.16.0",
    "react-test-renderer": "^16.7.0",
    "reactstrap": "^8.10.1",
    "serve": "9.1.0",
    "source-map-explorer": "^2.5.3",
    "tachyons-type-scale": "^6.1.1",
    "typescript": "^5.2.2",
    "vite": "^4.4.9",
    "vite-plugin-node-polyfills": "^0.14.1",
    "vite-plugin-svgr": "^3.2.0",
    "xlsx": "^0.18.5"
  },
  "prettier": {
    "printWidth": 80,
    "singleQuote": true,
    "semi": false,
    "trailingComma": "none",
    "bracketSpacing": true,
    "jsxBracketSameLine": false
  },
  "eslintConfig": {
    "env": {
      "browser": true,
      "es2021": true
    },
    "extends": [
      "eslint:recommended",
      "plugin:react/recommended"
    ],
    "parserOptions": {
      "ecmaVersion": "latest",
      "sourceType": "module"
    },
    "plugins": [
      "react"
    ],
    "rules": {}
  },
  "jest": {
    "collectCoverageFrom": [
      "src/components/Bootstrap/*.{js,jsx}",
      "!**/*.examples.{js,jsx}"
    ]
  },
  "browserslist": [
    ">0.2%",
    "Firefox ESR",
    "not dead",
    "not ie <= 11",
    "not op_mini all"
  ],
  "devDependencies": {
    "jscodeshift": "^0.15.0"
  }
}
