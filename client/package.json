{
  "name": "leihs-procurement-ui",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "start": "npm run -s build:i18n && vite",
    "serve": "vite preview",
    "build": "npm run -s build:i18n && npm run -s build:app",
    "build:app": "vite build",
    "build:i18n": "node src/locale/make-pseudoloc.js",
    "cleanup-typescript": "find . -type f -name '*.ts' -or -name '*.tsx' | xargs rm",
    "analyze": "source-map-explorer build/static/js/main.*",
    "analyze-build": "npm run -s build && npm run -s analyze",
    "lint": "eslint --fix 'src/**/*.{js,jsx}' && npm run -s lint:json",
    "ci:lint": "eslint 'src/**/*.{js,jsx}' && npm run -s ci:lint:json",
    "lint:json": "prettier --write 'src/{,**/}*.json'",
    "ci:lint:json": "prettier --list-different 'src/{,**/}*.json'",
    "test": "npm run -s build:i18n && vitest",
    "coverage": "vitest --coverage",
    "snapshots": "vitest -u"
  },
  "dependencies": {
    "@apollo/client": "^3.8.4",
    "@fortawesome/fontawesome-svg-core": "^6.7.2",
    "@fortawesome/free-regular-svg-icons": "^6.7.2",
    "@fortawesome/free-solid-svg-icons": "^6.7.2",
    "@fortawesome/react-fontawesome": "^0.2.0",
    "@popperjs/core": "^2.11.8",
    "@types/node": "^20.5.3",
    "@types/react": "^18.2.21",
    "@types/react-dom": "^18.2.7",
    "accounting-js": "^2.0.3",
    "bootstrap": "^4.2.1",
    "browser-info": "^1.2.0",
    "classnames": "^2.3.2",
    "cross-fetch": "^4.0.0",
    "debug": "^4.4.3",
    "downshift": "^1.31.16",
    "graphiql": "^5.2.2",
    "graphql": "^16.11.0",
    "graphql-tag": "^2.10.0",
    "graphql-ws": "^6.0.7",
    "lodash": "^4.17.11",
    "date-fns": "^4.1.0",
    "prop-types": "^15.6.2",
    "pseudoloc": "^1.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-highlight-words": "^0.21.0",
    "react-router": "^7.13.2",
    "react-router-dom": "^7.13.2",
    "react-test-renderer": "^18.2.0",
    "reactstrap": "^8.10.1",
    "tachyons-type-scale": "^6.1.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@typescript-eslint/utils": "^8.57.2",
    "@vitejs/plugin-react-swc": "^4.3.0",
    "@vitest/coverage-v8": "^4.1.1",
    "@vitest/ui": "^4.1.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-vitest": "^0.5.4",
    "eslint-plugin-vitest-globals": "^1.6.1",
    "globals": "^17.4.0",
    "jsdom": "^29.0.1",
    "prettier": "^3.8.1",
    "source-map-explorer": "^2.5.3",
    "typescript": "^6.0.2",
    "vite": "^7.3.1",
    "vite-plugin-monaco-editor": "^1.1.0",
    "vite-plugin-node-polyfills": "^0.25.0",
    "vite-plugin-svgr": "^4.3.0",
    "vitest": "^4.1.1"
  },
  "overrides": {
    "flatted": ">=3.4.1"
  }
}
